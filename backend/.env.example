# ── Server ───────────────────────────────────────────────────
PORT=3001

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── MySQL / XAMPP ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bingo

# ── Game Settings ─────────────────────────────────────────────
ENTRY_FEE=10
HOUSE_CUT_PERCENT=20

# ── Admin ─────────────────────────────────────────────────────
ADMIN_PHONES=09xxxxxxxx
ADMIN_PANEL_PASSWORD=your_admin_password

# ── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Wallet Limits ─────────────────────────────────────────────
MIN_DEPOSIT=10
MIN_WITHDRAW=10
MAX_WITHDRAW=5000
